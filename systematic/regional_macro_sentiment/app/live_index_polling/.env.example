# ── Permutable AI API ─────────────────────────────────────────────────────────
API_KEY=your-permutable-api-key-here
BASE_URL=https://copilot-api.permutable.ai/v1

# ── Regional Macro Model ───────────────────────────────────────────────────────
# Model ID: macro_1 | macro_2 | macro_3
MODEL_ID=macro_1

# ── Country and Topic Filters ──────────────────────────────────────────────────
# COUNTRY_PRESET: G20 | G7 | ALL | individual country name (e.g. "united states")
COUNTRY_PRESET=G20
TOPIC_PRESET=ALL
LANGUAGE_PRESET=ALL
SOURCE_PRESET=ALL
SOURCE_COUNTRY_PRESET=ALL

# ── Index Configuration ────────────────────────────────────────────────────────
# INDEX_TYPE: COMBINED | EXPLICIT | IMPLICIT
INDEX_TYPE=COMBINED
# sparse=true returns only buckets that contain headlines (recommended)
SPARSE=true
# align_to_period_end=true timestamps each bucket at the close of the hour
ALIGN_TO_PERIOD_END=true

# ── Polling ────────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=900
BACKFILL_DAYS=7

# ── Storage ────────────────────────────────────────────────────────────────────
DB_PATH=/data/macro_regional.db

# ── Sentiment Thresholds ───────────────────────────────────────────────────────
# sentiment_avg ∈ [−1, +1]. Narrower than conviction ratio thresholds because
# sentiment_avg is already a mean rather than a normalised ratio.
UPPER_THRESHOLD=0.5
LOWER_THRESHOLD=-0.5

# ── Dashboard ──────────────────────────────────────────────────────────────────
API_URL=http://api:8000
REFRESH_INTERVAL_MS=60000
