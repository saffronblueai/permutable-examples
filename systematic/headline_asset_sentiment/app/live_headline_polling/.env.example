# ── Permutable AI API ─────────────────────────────────────────────────────────
API_KEY=your-permutable-api-key-here
BASE_URL=https://copilot-api.permutable.ai/v1

# ── Tickers ────────────────────────────────────────────────────────────────────
# Comma-separated list of tickers included in your licence
TICKERS=BTC_CRY,ETH_CRY,BZ_COM,EUR_IND

# ── Request filters ────────────────────────────────────────────────────────────
MATCH_TYPE=COMBINED
TOPIC_PRESET=ALL
LANGUAGE_PRESET=ALL
SOURCE_PRESET=ALL
SOURCE_COUNTRY_PRESET=ALL
TOPIC_PROBABILITY_THRESHOLD=0.1
ABS_SENTIMENT_THRESHOLD=0.1

# ── Polling ────────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=900
BACKFILL_DAYS=7

# ── Storage ────────────────────────────────────────────────────────────────────
DB_PATH=/data/headline_sentiment.db

# ── Signal thresholds ──────────────────────────────────────────────────────────
BULLISH_THRESHOLD=0.05
BEARISH_THRESHOLD=-0.05

# ── Dashboard ──────────────────────────────────────────────────────────────────
API_URL=http://api:8000
REFRESH_INTERVAL_MS=60000
