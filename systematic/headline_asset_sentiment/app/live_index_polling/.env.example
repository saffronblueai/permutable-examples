# ── Permutable AI API ─────────────────────────────────────────────────────────
API_KEY=your-permutable-api-key-here
BASE_URL=https://copilot-api.permutable.ai/v1

# ── Tickers ────────────────────────────────────────────────────────────────────
# Comma-separated list of tickers included in your licence
TICKERS=BTC_CRY,ETH_CRY,BZ_COM,EUR_IND

# ── Index configuration ────────────────────────────────────────────────────────
# INDEX_TYPE: COMBINED | EXPLICIT | IMPLICIT
INDEX_TYPE=COMBINED
TOPIC_PRESET=ALL
# sparse=true returns only buckets that contain headlines (recommended)
SPARSE=true
# align_to_period_end=true timestamps each bucket at the close of the hour
ALIGN_TO_PERIOD_END=true

# ── Polling ────────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=900
BACKFILL_DAYS=7

# ── Storage ────────────────────────────────────────────────────────────────────
DB_PATH=/data/headline_index.db

# ── Sentiment thresholds ───────────────────────────────────────────────────────
# sentiment_avg = sentiment_sum / headline_count  ∈ [−1, +1]
UPPER_THRESHOLD=0.5
LOWER_THRESHOLD=-0.5

# ── Dashboard ──────────────────────────────────────────────────────────────────
API_URL=http://api:8000
REFRESH_INTERVAL_MS=60000
